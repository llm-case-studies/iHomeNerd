  "lines": [
    {
      "lineId": "en-001",
      "text": "Hello, how are you today?"
    },
    {
      "lineId": "en-002",
      "text": "Good morning."
    },
    {
      "lineId": "en-003",
      "text": "What time does the train leave for downtown?"
    },
    {
      "lineId": "en-004",
      "text": "Can you recommend a good restaurant nearby?"
    },
    {
      "lineId": "en-005",
      "text": "I have been thinking about learning a new language, maybe Spanish or Mandarin, but I am not sure which one would be more useful for my career."
    },
    {
      "lineId": "en-006",
      "text": "The weather this weekend looks perfect for hiking, so I am planning to head up to the mountains early Saturday morning and come back by Sunday evening."
    },
    {
      "lineId": "en-007",
      "text": "One, two, three, four, five, six, seven, eight, nine, ten."
    },
    {
      "lineId": "en-008",
      "text": "My name is Alex, and my friends are Maria, James, and Priya."
    },
    {
      "lineId": "en-009",
      "text": "The quick brown fox jumps over the lazy dog. The early bird catches the worm, but the second mouse gets the cheese."
    },
    {
      "lineId": "en-010",
      "text": "Okay, so let me check, did you say forty-two dollars or fifty-two dollars? I want to make sure I heard that right."
    }
  ],
