  "lines": [
    {
      "lineId": "ko-001",
      "text": "\uc548\ub155\ud558\uc138\uc694, \uc624\ub298 \uc5b4\ub5a0\uc138\uc694?"
    },
    {
      "lineId": "ko-002",
      "text": "\uc88b\uc740 \uc544\uce68\uc785\ub2c8\ub2e4."
    },
    {
      "lineId": "ko-003",
      "text": "\uc2dc\ub0b4\ub85c \uac00\ub294 \uae30\ucc28\ub294 \uba87 \uc2dc\uc5d0 \ucd9c\ubc1c\ud558\ub098\uc694?"
    },
    {
      "lineId": "ko-004",
      "text": "\uc774 \uadfc\ucc98\uc5d0 \uc88b\uc740 \uc2dd\ub2f9 \ud558\ub098 \ucd94\ucc9c\ud574 \uc8fc\uc2e4 \uc218 \uc788\ub098\uc694?"
    },
    {
      "lineId": "ko-005",
      "text": "\uc0c8\ub85c\uc6b4 \uc5b8\uc5b4\ub97c \ubc30\uc6b0\ub824\uace0 \uc0dd\uac01\ud558\uace0 \uc788\ub294\ub370, \uc2a4\ud398\uc778\uc5b4\uc640 \uc911\uad6d\uc5b4 \uc911\uc5d0\uc11c \uc81c \uc77c\uc5d0 \ub354 \ub3c4\uc6c0\uc774 \ub420 \uc5b8\uc5b4\uac00 \ubb34\uc5c7\uc778\uc9c0 \uc544\uc9c1 \uc798 \ubaa8\ub974\uaca0\uc2b5\ub2c8\ub2e4."
    },
    {
      "lineId": "ko-006",
      "text": "\uc774\ubc88 \uc8fc\ub9d0 \ub0a0\uc528\uac00 \ud558\uc774\ud0b9\ud558\uae30\uc5d0 \ub531 \uc88b\uc744 \uac83 \uac19\uc544\uc11c \ud1a0\uc694\uc77c \uc544\uce68 \uc77c\ucc0d \uc0b0\uc73c\ub85c \ub5a0\ub0ac\ub2e4\uac00 \uc77c\uc694\uc77c \uc800\ub141\uc5d0 \ub3cc\uc544\uc62c \uc0dd\uac01\uc785\ub2c8\ub2e4."
    },
    {
      "lineId": "ko-007",
      "text": "\ud558\ub098, \ub458, \uc14b, \ub137, \ub2e4\uc12f, \uc5ec\uc12f, \uc77c\uacf1, \uc5ec\ub35f, \uc544\ud649, \uc5f4."
    },
    {
      "lineId": "ko-008",
      "text": "\uc81c \uc774\ub984\uc740 Alex\uc774\uace0, \uc81c \uce5c\uad6c\ub4e4\uc740 Maria, James, \uadf8\ub9ac\uace0 Sofia\uc785\ub2c8\ub2e4."
    },
    {
      "lineId": "ko-009",
      "text": "\uc624\ub298 \uc544\uce68\uc5d0\ub294 \uc77c\ucc0d \uc9d1\uc744 \ub098\uc640 \uc5ec\ub35f \uc2dc \uc804\uc5d0 \ud68c\uc0ac\uc5d0 \ub3c4\ucc29\ud588\uc2b5\ub2c8\ub2e4. \uc810\uc2ec \uc2dd\uc0ac \ud6c4\uc5d0\ub294 \ud300\uacfc \uc9e7\uc740 \ud68c\uc758\ub97c \ud588\uc2b5\ub2c8\ub2e4."
    },
    {
      "lineId": "ko-010",
      "text": "\ud655\uc778 \uc880 \ud560\uac8c\uc694. \ubc29\uae08 \uc0ac\uc2ed\uc774 \uc720\ub85c\ub77c\uace0 \ud558\uc168\ub098\uc694, \uc544\ub2c8\uba74 \uc624\uc2ed\uc774 \uc720\ub85c\ub77c\uace0 \ud558\uc168\ub098\uc694? \uc81c\uac00 \uc81c\ub300\ub85c \ub4e4\uc5c8\ub294\uc9c0 \ud655\uc778\ud558\uace0 \uc2f6\uc2b5\ub2c8\ub2e4."
    }
  ],
