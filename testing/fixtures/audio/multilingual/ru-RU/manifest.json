{
  "packId": "ihn-test-ru-ru-v1",
  "lang": "ru-RU",
  "voices": [
    {
      "id": "canonical-female",
      "label": "Canonical female",
      "sourceKind": "cloud_tts",
      "provider": "azure-speech",
      "providerVoiceId": "ru-RU-SvetlanaNeural",
      "lang": "ru-RU",
      "styleNote": "neutral testing voice"
    }
  ],
  "lines": [
    {
      "lineId": "ru-001",
      "text": "\u0417\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439\u0442\u0435, \u043a\u0430\u043a \u0432\u044b \u0441\u0435\u0433\u043e\u0434\u043d\u044f?"
    },
    {
      "lineId": "ru-002",
      "text": "\u0414\u043e\u0431\u0440\u043e\u0435 \u0443\u0442\u0440\u043e."
    },
    {
      "lineId": "ru-003",
      "text": "\u0412\u043e \u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043f\u043e\u0435\u0437\u0434 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0432 \u0446\u0435\u043d\u0442\u0440?"
    },
    {
      "lineId": "ru-004",
      "text": "\u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u043f\u043e\u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u043e\u0432\u0430\u0442\u044c \u0445\u043e\u0440\u043e\u0448\u0438\u0439 \u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d \u043f\u043e\u0431\u043b\u0438\u0437\u043e\u0441\u0442\u0438?"
    },
    {
      "lineId": "ru-005",
      "text": "\u042f \u043f\u043e\u0434\u0443\u043c\u044b\u0432\u0430\u044e \u0432\u044b\u0443\u0447\u0438\u0442\u044c \u043d\u043e\u0432\u044b\u0439 \u044f\u0437\u044b\u043a, \u043c\u043e\u0436\u0435\u0442 \u0431\u044b\u0442\u044c \u0438\u0441\u043f\u0430\u043d\u0441\u043a\u0438\u0439 \u0438\u043b\u0438 \u043a\u0438\u0442\u0430\u0439\u0441\u043a\u0438\u0439, \u043d\u043e \u043f\u043e\u043a\u0430 \u043d\u0435 \u0437\u043d\u0430\u044e, \u043a\u0430\u043a\u043e\u0439 \u0431\u0443\u0434\u0435\u0442 \u043f\u043e\u043b\u0435\u0437\u043d\u0435\u0435 \u0434\u043b\u044f \u043c\u043e\u0435\u0439 \u0440\u0430\u0431\u043e\u0442\u044b."
    },
    {
      "lineId": "ru-006",
      "text": "\u041d\u0430 \u044d\u0442\u0438\u0445 \u0432\u044b\u0445\u043e\u0434\u043d\u044b\u0445 \u043e\u0431\u0435\u0449\u0430\u044e\u0442 \u043e\u0442\u043b\u0438\u0447\u043d\u0443\u044e \u043f\u043e\u0433\u043e\u0434\u0443 \u0434\u043b\u044f \u043f\u043e\u0445\u043e\u0434\u0430, \u043f\u043e\u044d\u0442\u043e\u043c\u0443 \u044f \u043f\u043b\u0430\u043d\u0438\u0440\u0443\u044e \u0440\u0430\u043d\u043e \u0443\u0442\u0440\u043e\u043c \u0432 \u0441\u0443\u0431\u0431\u043e\u0442\u0443 \u043f\u043e\u0435\u0445\u0430\u0442\u044c \u0432 \u0433\u043e\u0440\u044b \u0438 \u0432\u0435\u0440\u043d\u0443\u0442\u044c\u0441\u044f \u0432 \u0432\u043e\u0441\u043a\u0440\u0435\u0441\u0435\u043d\u044c\u0435 \u0432\u0435\u0447\u0435\u0440\u043e\u043c."
    },
    {
      "lineId": "ru-007",
      "text": "\u041e\u0434\u0438\u043d, \u0434\u0432\u0430, \u0442\u0440\u0438, \u0447\u0435\u0442\u044b\u0440\u0435, \u043f\u044f\u0442\u044c, \u0448\u0435\u0441\u0442\u044c, \u0441\u0435\u043c\u044c, \u0432\u043e\u0441\u0435\u043c\u044c, \u0434\u0435\u0432\u044f\u0442\u044c, \u0434\u0435\u0441\u044f\u0442\u044c."
    },
    {
      "lineId": "ru-008",
      "text": "\u041c\u0435\u043d\u044f \u0437\u043e\u0432\u0443\u0442 \u0410\u043b\u0435\u043a\u0441, \u0430 \u043c\u043e\u0438\u0445 \u0434\u0440\u0443\u0437\u0435\u0439 \u0437\u043e\u0432\u0443\u0442 \u041c\u0430\u0440\u0438\u044f, \u042f\u043a\u043e\u0432 \u0438 \u0421\u043e\u0444\u0438\u044f."
    },
    {
      "lineId": "ru-009",
      "text": "\u0421\u0435\u0433\u043e\u0434\u043d\u044f \u0443\u0442\u0440\u043e\u043c \u044f \u0432\u044b\u0448\u0435\u043b \u0438\u0437 \u0434\u043e\u043c\u0430 \u0440\u0430\u043d\u043e \u0438 \u043f\u0440\u0438\u0435\u0445\u0430\u043b \u043d\u0430 \u0440\u0430\u0431\u043e\u0442\u0443 \u0434\u043e \u0432\u043e\u0441\u044c\u043c\u0438. \u041f\u043e\u0441\u043b\u0435 \u043e\u0431\u0435\u0434\u0430 \u0443 \u043d\u0430\u0441 \u0431\u044b\u043b\u0430 \u0435\u0449\u0451 \u043a\u043e\u0440\u043e\u0442\u043a\u0430\u044f \u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u0441 \u043a\u043e\u043c\u0430\u043d\u0434\u043e\u0439."
    },
    {
      "lineId": "ru-010",
      "text": "\u0414\u0430\u0432\u0430\u0439\u0442\u0435 \u0443\u0442\u043e\u0447\u043d\u044e: \u0432\u044b \u0441\u043a\u0430\u0437\u0430\u043b\u0438 \u0441\u043e\u0440\u043e\u043a \u0434\u0432\u0430 \u0435\u0432\u0440\u043e \u0438\u043b\u0438 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442 \u0434\u0432\u0430 \u0435\u0432\u0440\u043e? \u042f \u0445\u043e\u0447\u0443 \u0443\u0431\u0435\u0434\u0438\u0442\u044c\u0441\u044f, \u0447\u0442\u043e \u0440\u0430\u0441\u0441\u043b\u044b\u0448\u0430\u043b \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e."
    }
  ],
